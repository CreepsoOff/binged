# =========================
# macOS / Système
# =========================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
*.swp

# =========================
# Xcode
# =========================
# Dossiers de build (générés localement)
build/
DerivedData/

# Préférences utilisateurs (Ne pas partager sur Git)
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/

# Fichiers d'états et de gestion de version internes à Xcode
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint

# =========================
# Swift Package Manager (SPM)
# =========================
.build/
 binged.xcodeproj/project.xcworkspace/xcuserdata/*
 binged.xcodeproj/xcuserdata/*
# =========================
# Visual Studio Code
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# =========================
# CocoaPods (Si tu en utilises plus tard)
# =========================
# On ignore le dossier Pods car il peut être lourd et généré via 'pod install'
Pods/
# Mais on GARDE le Podfile.lock pour que tout le monde ait les mêmes versions
!Podfile.lock

# =========================
# Fichiers de Crash / Logs
# =========================
*.crash
*.log

# =========================
# Fastlane (Si tu automatises tes déploiements plus tard)
# =========================
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
